# Copy to /etc/pve-esp32-bridge.env inside the LXC.

# If the bridge runs inside an LXC, this is the IP of the Proxmox host.
# If the bridge runs directly on the Proxmox host, you can use https://127.0.0.1:8006.
PVE_HOST=https://192.168.1.20:8006

# Proxmox node name as shown in the left sidebar.
PVE_NODE=pve

# Recommended token format: user@realm!token-name
PVE_TOKEN_ID=esp32-dashboard@pve!metrics
PVE_TOKEN_SECRET=CHANGE_ME

# Set false if Proxmox uses the default self-signed certificate.
PVE_VERIFY_SSL=false

# The ESP32 will call http://LXC_IP:8080/metrics.
LISTEN_HOST=0.0.0.0
LISTEN_PORT=8080
